# Environment variables for mgkomik mirror proxy
# Copy this to .env and adjust values

# The source website to mirror
SOURCE_HOST=id.mgkomik.cc

# Your mirror domain
MIRROR_HOST=mgkomik.co

# Port to listen on (Railway/Render set this automatically)
PORT=3000

# Cookie refresh interval in milliseconds (default: 10 minutes)
COOKIE_REFRESH_MS=600000

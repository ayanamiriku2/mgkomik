# Environment variables for mgkomik mirror proxy
# Copy this to .env and adjust values

# The source website to mirror
SOURCE_HOST=id.mgkomik.cc

# Your mirror domain
MIRROR_HOST=mgkomik.co

# Port to listen on (Railway/Render set this automatically)
PORT=3000

# Residential proxy list (one per line, format: IP:PORT:USER:PASS)
# Proxies are rotated round-robin on every request.
# If not set, built-in proxy list is used.
# PROXY_LIST=209.74.82.48:30000:mgproxy:MgProxy1775215572
# 209.74.82.48:30001:mgproxy:MgProxy1775215572

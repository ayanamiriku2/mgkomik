# Environment variables for mgkomik mirror proxy
# Copy this to .env and adjust values

# The source website to mirror
SOURCE_HOST=id.mgkomik.cc

# Your mirror domain
MIRROR_HOST=mgkomik.co

# Port to listen on (Railway/Render set this automatically)
PORT=3000

# Cloudflare Worker URL (REQUIRED for Railway/cloud deployment)
# Deploy worker.js on Cloudflare Workers, then paste the URL here.
# See worker.js for setup instructions.
WORKER_URL=https://mgkomik-proxy.YOUR-SUBDOMAIN.workers.dev

# Optional: Auth key to protect your Worker from unauthorized use
# Must match the AUTH_KEY secret in your Cloudflare Worker settings
WORKER_AUTH_KEY=
